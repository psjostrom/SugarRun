<settings>
    <setting propertyKey="@Properties.nightscoutUrl" title="@Strings.nightscoutUrlTitle">
        <settingConfig type="alphaNumeric" />
    </setting>
    <setting propertyKey="@Properties.nightscoutSecret" title="@Strings.nightscoutSecretTitle">
        <settingConfig type="alphaNumeric" />
    </setting>
    <setting propertyKey="@Properties.bgLow" title="@Strings.bgLowTitle">
        <settingConfig type="list">
            <listEntry value="30">3.0</listEntry>
            <listEntry value="35">3.5</listEntry>
            <listEntry value="40">4.0</listEntry>
            <listEntry value="45">4.5</listEntry>
            <listEntry value="50">5.0</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.bgHigh" title="@Strings.bgHighTitle">
        <settingConfig type="list">
            <listEntry value="70">7.0</listEntry>
            <listEntry value="80">8.0</listEntry>
            <listEntry value="90">9.0</listEntry>
            <listEntry value="100">10.0</listEntry>
            <listEntry value="110">11.0</listEntry>
            <listEntry value="120">12.0</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.bgFontSize" title="@Strings.bgFontSizeTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.fontCustom</listEntry>
            <listEntry value="1">@Strings.fontSystem</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.vAlign" title="@Strings.vAlignTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.alignTop</listEntry>
            <listEntry value="1">@Strings.alignMiddle</listEntry>
            <listEntry value="2">@Strings.alignBottom</listEntry>
        </settingConfig>
    </setting>
</settings>
